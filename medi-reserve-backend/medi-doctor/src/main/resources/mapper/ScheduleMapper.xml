<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.medireserve.doctor.mapper.ScheduleMapper">

    <!-- ========================================================= -->
    <!-- 3. 根据医生ID和日期范围查询排班列表（动态SQL） -->
    <!-- ========================================================= -->
    <select id="findByDoctorIdAndDateRange" resultType="Schedule">
        select *
        from schedule where doctor_id = #{doctorId}
        <if test="startDate != null">
            and schedule_date &gt;= #{startDate}
        </if>
        <if test="endDate != null">
            and schedule_date &lt;= #{endDate}
        </if>
        order by schedule_date asc , period asc
    </select>

</mapper>